# ══════════════════════════════════════════════════════════════════════════════
# rsvp-party-template — Variables de entorno
#
# Para desarrollo local:
#   cp .env.example .env.local
#   (editar .env.local con los valores reales)
#
# Para producción:
#   Configurar en Vercel → Settings → Environment Variables
#
# ⚠️ NUNCA subas .env.local al repositorio
# ══════════════════════════════════════════════════════════════════════════════


# ── CONFIGURACIÓN DEL EVENTO ──────────────────────────────────────────────────
# Estos son los únicos valores que necesitás cambiar para un nuevo evento

# Nombre del evento / los cumpleañeros (aparece en título, hero, email)
NEXT_PUBLIC_EVENT_NAME="Cumple Carme & Inne"

# Fecha y hora del evento en ISO 8601 con offset Argentina (UTC-3)
# Formato: YYYY-MM-DDTHH:MM:SS-03:00
NEXT_PUBLIC_EVENT_DATE="2026-04-25T15:00:00-03:00"

# Nombre del lugar del evento
NEXT_PUBLIC_EVENT_LOCATION="Gravity Park"

# Dirección completa del lugar
NEXT_PUBLIC_EVENT_ADDRESS="Av. Gaona 1837, Caballito"

# Texto amigable de la fecha para mostrar en pantalla (sin repetir el año si no hace falta)
NEXT_PUBLIC_EVENT_DATE_FRIENDLY="Sábado 25 de abril"

# Hora amigable para mostrar en pantalla
NEXT_PUBLIC_EVENT_TIME_FRIENDLY="15:00 hs"

# Query para Google Maps (reemplazar espacios con +)
NEXT_PUBLIC_EVENT_MAP_QUERY="Gravity+Park,+Av.+Gaona+1837,+Caballito,+Buenos+Aires"

# Ruta a la imagen de la tarjeta de invitación (relativa a /public)
NEXT_PUBLIC_INVITATION_IMAGE="/assets/invitation-card.jpg"


# ── BACKEND / GOOGLE APPS SCRIPT ─────────────────────────────────────────────
# URL del Apps Script desplegado como Web App
# ⚠️ SIN prefijo NEXT_PUBLIC_ → solo existe en el servidor (seguro)
APPS_SCRIPT_URL=https://script.google.com/macros/s/REEMPLAZAR_CON_TU_URL/exec


# ── URL BASE DE LA APP ────────────────────────────────────────────────────────
# Necesaria para que el SSR pueda llamar a /api/count al renderizar
# Desarrollo: http://localhost:3000
# Producción: https://TU-APP.vercel.app (Vercel lo asigna automáticamente)
NEXT_PUBLIC_APP_URL=http://localhost:3000
